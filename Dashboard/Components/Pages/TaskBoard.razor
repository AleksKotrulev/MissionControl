@page "/"
@using MissionControl.Dashboard.Services
@using MissionControl.Tasks
@inject DashboardDataService Data
@implements IDisposable

<div class="page-header">
    <h1>Task Board</h1>
    <p class="subtitle">Track and manage all tasks across agents</p>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
        </div>
        <div class="stat-value">@_tasks.Count</div>
        <div class="stat-label">Total Tasks</div>
    </div>
    <div class="stat-card info">
        <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
        </div>
        <div class="stat-value">@GetTasksByStatus(TaskItemStatus.InProgress).Count</div>
        <div class="stat-label">In Progress</div>
    </div>
    <div class="stat-card success">
        <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>
        <div class="stat-value">@GetTasksByStatus(TaskItemStatus.Done).Count</div>
        <div class="stat-label">Completed</div>
    </div>
    <div class="stat-card danger">
        <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <div class="stat-value">@_tasks.Count(t => t.Priority == TaskPriority.Critical)</div>
        <div class="stat-label">Critical</div>
    </div>
</div>

<div class="kanban-board">
    @{ var statusList = new[] { TaskItemStatus.NotStarted, TaskItemStatus.InProgress, TaskItemStatus.Done, TaskItemStatus.Failed }; }
    @foreach (var status in statusList)
    {
        var tasks = GetTasksByStatus(status);
        var colClass = status switch
        {
            TaskItemStatus.NotStarted => "col-notstarted",
            TaskItemStatus.InProgress => "col-inprogress",
            TaskItemStatus.Done => "col-done",
            TaskItemStatus.Failed => "col-failed",
            _ => ""
        };

        <div class="kanban-column @colClass">
            <h3>
                @FormatStatus(status)
                <span class="count">@tasks.Count</span>
            </h3>
            @if (tasks.Count == 0)
            {
                <div class="empty-column">No tasks</div>
            }
            else
            {
                var idx = 0;
                @foreach (var task in tasks)
                {
                    <div class="kanban-card priority-@task.Priority.ToString().ToLower()" style="animation-delay: @(idx * 50)ms">
                        <div class="card-title">@task.Title</div>
                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <div class="card-description">@task.Description</div>
                        }
                        <div class="card-meta">
                            <span class="badge">@task.Priority</span>
                            @if (!string.IsNullOrWhiteSpace(task.AssignedTo))
                            {
                                <span class="agent">@task.AssignedTo</span>
                            }
                            @if (task.AttemptCount > 0)
                            {
                                <span class="attempts">Attempt @task.AttemptCount</span>
                            }
                        </div>
                        @if (task.SubTasks.Count > 0)
                        {
                            <div class="subtasks">@task.SubTasks.Count(s => s.Completed)/@task.SubTasks.Count subtasks</div>
                        }
                    </div>
                    idx++;
                }
            }
        </div>
    }
</div>

@code {
    private List<TaskItem> _tasks = [];
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _timer = new Timer(async _ =>
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }, null, 5000, 5000);
    }

    private async Task RefreshAsync() => _tasks = await Data.GetTasksAsync();

    private List<TaskItem> GetTasksByStatus(TaskItemStatus status) =>
        _tasks.Where(t => t.Status == status).OrderByDescending(t => t.Priority).ToList();

    private static string FormatStatus(TaskItemStatus status) => status switch
    {
        TaskItemStatus.NotStarted => "Not Started",
        TaskItemStatus.InProgress => "In Progress",
        _ => status.ToString()
    };

    public void Dispose() => _timer?.Dispose();
}
